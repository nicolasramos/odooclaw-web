---
import '../styles/globals.css';
import Github from '../components/icons/Github.astro';
import BookText from '../components/icons/BookText.astro';
import Share2 from '../components/icons/Share2.astro';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>OdooClaw | AI built to run where your ERP lives</title>
		<meta name="description" content="OdooClaw is an ultra-lightweight AI assistant for Odoo ERP, written in Go, with native Discuss integration and permission inheritance.">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#edf8ff] text-[#213138] font-inter">
		<!-- Navigation -->
		<nav class="sticky top-0 z-50 glass border-b border-outline-variant/15 flex items-center justify-between px-6 py-4 md:px-12">
			<div class="flex items-center gap-2">
				<div class="w-10 h-10 bg-gradient-to-br from-primary to-primary-container rounded-lg flex items-center justify-center text-white font-manrope font-extrabold text-xl shadow-premium">OC</div>
				<span class="font-manrope font-bold text-xl tracking-tighter">OdooClaw</span>
			</div>
			
			<div class="hidden md:flex items-center gap-8 font-medium">
				<a href="#features" class="hover:text-primary transition-colors">Features</a>
				<a href="#architecture" class="hover:text-primary transition-colors">Architecture</a>
				<a href="#security" class="hover:text-primary transition-colors">Security</a>
				<a href="/docs/intro" class="hover:text-primary transition-colors">Docs</a>
			</div>
			
			<div class="flex items-center gap-3">
				<a href="https://github.com/nicolasramos/odooclaw" class="hidden sm:flex items-center gap-2 text-on-surface-variant hover:text-on-surface transition-colors font-medium">
					<Github size={20} />
					<span>GitHub</span>
				</a>
				<a href="/docs/quickstart" class="btn-primary flex items-center gap-2 px-6 py-2.5">
					<span>Get Started</span>
				</a>
			</div>
		</nav>

		<main>
			<!-- Hero Section -->
			<section class="relative pt-24 pb-32 px-6 md:px-12 overflow-hidden">
				<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16 relative z-10">
					<div class="flex-1 text-center md:text-left">
						<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-sm mb-8 animate-fade-in-up">
							<span class="relative flex h-2 w-2">
								<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
								<span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
							</span>
							Odoo 18 Ready
						</div>
						<h1 class="font-manrope text-5xl md:text-7xl font-extrabold mb-8 tracking-tighter leading-[1.1]">
							AI built to run where your <span class="bg-gradient-to-r from-primary to-primary-container bg-clip-text text-transparent">ERP lives.</span>
						</h1>
						<p class="text-xl md:text-2xl text-on-surface-variant mb-12 max-w-2xl leading-relaxed">
							The most lightweight AI assistant for Odoo. Native Discuss integration, permission-aware actions, and sub-10MB RAM footprint.
						</p>
						<div class="flex flex-col sm:flex-row items-center gap-4 justify-center md:justify-start">
							<a href="/docs/quickstart" class="btn-primary px-10 py-4 text-lg w-full sm:w-auto text-center shadow-premium-lg">
								Quick Start Guide
							</a>
							<a href="https://github.com/nicolasramos/odooclaw" class="btn-secondary px-10 py-4 text-lg w-full sm:w-auto text-center flex items-center justify-center gap-3">
								<Github size={22} />
								View on GitHub
							</a>
						</div>
						
						<!-- Fast Stats -->
						<div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-20 max-w-4xl opacity-80 border-t border-outline-variant/15 pt-12">
							<div>
								<p class="text-3xl font-manrope font-extrabold text-primary mb-1 tracking-tighter">&lt;10MB</p>
								<p class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">RAM Footprint</p>
							</div>
							<div>
								<p class="text-3xl font-manrope font-extrabold text-primary mb-1 tracking-tighter">Native</p>
								<p class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Odoo Actions</p>
							</div>
							<div>
								<p class="text-3xl font-manrope font-extrabold text-primary mb-1 tracking-tighter">100%</p>
								<p class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">ACL Aware</p>
							</div>
							<div>
								<p class="text-3xl font-manrope font-extrabold text-primary mb-1 tracking-tighter">Zero</p>
								<p class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">External Context</p>
							</div>
						</div>
					</div>
					
					<!-- UI Mockup / Visual -->
					<div class="flex-1 w-full max-w-2xl animate-fade-in-left">
						<div class="card-premium p-1 relative">
							<div class="bg-on-surface rounded-lg aspect-video p-6 text-white font-mono text-sm overflow-hidden relative shadow-2xl">
								<div class="flex items-center gap-2 mb-6 border-b border-white/10 pb-4">
									<div class="w-3 h-3 rounded-full bg-red-500"></div>
									<div class="w-3 h-3 rounded-full bg-yellow-500"></div>
									<div class="w-3 h-3 rounded-full bg-green-500"></div>
									<span class="ml-4 opacity-40">odooclaw-worker-1</span>
								</div>
								<div class="space-y-3">
									<p class="text-blue-400 font-bold">INFO <span class="text-white font-normal">[2024-03-26 16:45:12]</span> Initializing OdooClaw engine...</p>
									<p class="text-green-400 font-bold">INFO <span class="text-white font-normal">[2024-03-26 16:45:13]</span> Sub-10MB RAM footprint confirmed.</p>
									<p class="text-purple-400 font-bold">INFO <span class="text-white font-normal">[2024-03-26 16:45:14]</span> Odoo Discuss webhook listener active @ :18790</p>
									<p class="mt-8 text-white/60"># Receiving message from Discuss...</p>
									<div class="logic-node border-l-primary bg-white/5 border border-white/10 p-4 rounded-xl mt-4">
										<p class="text-primary-container font-bold mb-1">Detecting Intent: Summarize CRM Leads</p>
										<p class="flex items-center gap-2 text-white/80">
											<span class="text-green-400">✓</span> Inheriting user ACLs
										</p>
										<p class="flex items-center gap-2 text-white/80">
											<span class="text-green-400">✓</span> Querying Odoo XML-RPC
										</p>
									</div>
									<p class="animate-pulse flex items-center gap-2 mt-6">
										<span class="w-2 h-2 rounded-full bg-primary shadow-[0_0_8px_rgba(150,34,170,1)]"></span>
										Executing odoo-manager...
									</p>
								</div>
								
								<!-- Background Glow -->
								<div class="absolute -bottom-10 -right-10 w-48 h-48 bg-primary/30 rounded-full blur-[80px]"></div>
							</div>
						</div>
					</div>
				</div>
				
				<!-- Decorative elements -->
				<div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/2 -z-0"></div>
				<div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-[100px] translate-y-1/2 -translate-x-1/4 -z-0"></div>
			</section>

			<!-- Features Section -->
			<section id="features" class="py-32 px-6 md:px-12 bg-surface-container-low">
				<div class="max-w-7xl mx-auto">
					<div class="text-center mb-24">
						<h2 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight">Everything you need, <br/>nothing you don't.</h2>
						<p class="text-xl text-on-surface-variant max-w-2xl mx-auto">Built in Go for extreme performance. OdooClaw isn't just another chatbot—it's an operational extension of your ERP.</p>
					</div>
					
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						<!-- Feature Card 1 -->
						<div class="card-premium p-8 group transition-all hover:-translate-y-2">
							<div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 transition-colors group-hover:bg-primary group-hover:text-white">
								<BookText size={28} />
							</div>
							<h3 class="text-2xl font-bold mb-4">Discuss Integration</h3>
							<p class="text-on-surface-variant leading-relaxed mb-6">Talk to OdooClaw directly from Odoo Discuss. Mentions, channels, and private threads—all supported natively with zero context bleed.</p>
							<div class="logic-node p-3 bg-primary/5 border border-primary/10">
								<p class="text-xs font-bold text-primary mb-1 uppercase tracking-widest">Async Workflow</p>
								<p class="text-sm">Webhook-based architecture releases Odoo workers instantly.</p>
							</div>
						</div>
						
						<!-- Feature Card 2 -->
						<div class="card-premium p-8 group transition-all hover:-translate-y-2">
							<div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 transition-colors group-hover:bg-primary group-hover:text-white">
								<Share2 size={28} />
							</div>
							<h3 class="text-2xl font-bold mb-4">Permission Awareness</h3>
							<p class="text-on-surface-variant leading-relaxed mb-6">Security first. OdooClaw deep-links into the Odoo session to respect Record Rules and Access Control Lists exactly like a human user.</p>
							<div class="logic-node p-3 bg-primary/5 border border-primary/10">
								<p class="text-xs font-bold text-primary mb-1 uppercase tracking-widest">ORM Bridge</p>
								<p class="text-sm">Intelligent logic layer prevents halluncinations during XML-RPC calls.</p>
							</div>
						</div>

						<!-- Feature Card 3 -->
						<div class="card-premium p-8 group transition-all hover:-translate-y-2">
							<div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 transition-colors group-hover:bg-primary group-hover:text-white">
								<Github size={28} />
							</div>
							<h3 class="text-2xl font-bold mb-4">MCP Ecosystem</h3>
							<p class="text-on-surface-variant leading-relaxed mb-6">Fully extensible via Model Context Protocol. Built-in tools for OCR, Voice STT/TTS, and deep Odoo data manipulation.</p>
							<div class="logic-node p-3 bg-primary/5 border border-primary/10">
								<p class="text-xs font-bold text-primary mb-1 uppercase tracking-widest">Multi-modal</p>
								<p class="text-sm">Processes PDF invoices, Excel reports, and Voice notes with precision.</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Security Section -->
			<section id="security" class="py-32 px-6 md:px-12 bg-surface text-center">
				<div class="max-w-4xl mx-auto">
					<div class="inline-block px-4 py-1 rounded-full border border-primary text-primary font-bold text-sm mb-8">Authoritative Innovation</div>
					<h2 class="text-4xl md:text-5xl font-extrabold mb-10 tracking-tight">Enterprise security, by design.</h2>
					<p class="text-xl text-on-surface-variant mb-16 leading-relaxed">
						OdooClaw doesn't just read data—it respects your entire security architecture. No backdoors, no direct SQL, just clean, authenticated ORM interaction.
					</p>
					
					<div class="grid grid-cols-1 md:grid-cols-2 gap-12 text-left">
						<div class="flex gap-4">
							<div class="w-8 h-8 rounded-full bg-green-500/10 text-green-600 flex-shrink-0 flex items-center justify-center font-bold">✓</div>
							<div>
								<h4 class="font-bold text-xl mb-2">Non-Destructive Defaults</h4>
								<p class="text-on-surface-variant">Self-aware prompts. The AI will never delete records without explicit user confirmation.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-8 h-8 rounded-full bg-green-500/10 text-green-600 flex-shrink-0 flex items-center justify-center font-bold">✓</div>
							<div>
								<h4 class="font-bold text-xl mb-2">Isolated Context</h4>
								<p class="text-on-surface-variant">Conversation memory is segregated by Odoo thread. Privacy is maintained across users and channels.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-8 h-8 rounded-full bg-green-500/10 text-green-600 flex-shrink-0 flex items-center justify-center font-bold">✓</div>
							<div>
								<h4 class="font-bold text-xl mb-2">Sandboxed Runtime</h4>
								<p class="text-on-surface-variant">Embedded Python skills run in restricted environments. No lateral movement on your host system.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-8 h-8 rounded-full bg-green-500/10 text-green-600 flex-shrink-0 flex items-center justify-center font-bold">✓</div>
							<div>
								<h4 class="font-bold text-xl mb-2">Audit-Log Friendly</h4>
								<p class="text-on-surface-variant">Every action performed by OdooClaw is logged in the Discuss chatter, visible to your team.</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Call to Action -->
			<section class="py-24 px-6 md:px-12">
				<div class="max-w-6xl mx-auto rounded-3xl bg-gradient-to-br from-on-surface to-[#111] p-12 md:p-20 text-white relative overflow-hidden shadow-2xl">
					<div class="relative z-10 text-center flex flex-col items-center">
						<h2 class="text-4xl md:text-6xl font-extrabold mb-8 tracking-tighter">Ready to supercharge Odoo?</h2>
						<p class="text-xl md:text-2xl text-white/70 mb-12 max-w-2xl">
							Download the binary, configure your providers, and start automating in under 5 minutes.
						</p>
						<div class="flex flex-col sm:flex-row items-center gap-6">
							<a href="/docs/quickstart" class="btn-primary-white bg-white text-on-surface px-12 py-5 rounded-full font-bold text-xl shadow-premium hover:bg-white/90 transition-all active:scale-95">
								Get the QuickStart
							</a>
							<a href="https://github.com/nicolasramos/odooclaw" class="text-white font-bold text-xl flex items-center gap-3 hover:text-primary-container transition-colors">
								<Github size={28} />
								Clone on GitHub
							</a>
						</div>
					</div>
					
					<!-- Decorative Background -->
					<div class="absolute -top-20 -left-20 w-80 h-80 bg-primary/20 rounded-full blur-[100px]"></div>
					<div class="absolute -bottom-20 -right-20 w-80 h-80 bg-primary/10 rounded-full blur-[100px]"></div>
				</div>
			</section>
		</main>

		<footer class="bg-surface-container-highest py-20 px-6 md:px-12 border-t border-outline-variant/15">
			<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
				<div class="col-span-1 md:col-span-2">
					<div class="flex items-center gap-2 mb-6">
						<div class="w-8 h-8 bg-gradient-to-br from-primary to-primary-container rounded-lg flex items-center justify-center text-white font-manrope font-extrabold text-sm">OC</div>
						<span class="font-manrope font-bold text-xl tracking-tighter">OdooClaw</span>
					</div>
					<p class="text-on-surface-variant max-w-sm mb-8 leading-relaxed">
						OdooClaw is open-source software built for businesses that value speed, security, and precision. Built to bridge the gap between Odoo ERP and high-performance AI Agents.
					</p>
					<div class="flex items-center gap-6 grayscale opacity-60 hover:grayscale-0 transition-all">
						<img src="https://img.shields.io/badge/Go-1.21+-00ADD8?style=flat&logo=go&logoColor=white" alt="Go">
						<img src="https://img.shields.io/badge/Odoo-17%20%7C%2018-F68B20?style=flat&logo=odoo&logoColor=white" alt="Odoo">
					</div>
				</div>
				
				<div>
					<h5 class="font-bold text-lg mb-6 tracking-tight">Project</h5>
					<ul class="space-y-4 text-on-surface-variant">
						<li><a href="#features" class="hover:text-primary transition-colors">Key Features</a></li>
						<li><a href="#architecture" class="hover:text-primary transition-colors">Architecture</a></li>
						<li><a href="#security" class="hover:text-primary transition-colors">Security Model</a></li>
						<li><a href="/docs/intro" class="hover:text-primary transition-colors">Documentation</a></li>
					</ul>
				</div>
				
				<div>
					<h5 class="font-bold text-lg mb-6 tracking-tight">Connect</h5>
					<ul class="space-y-4 text-on-surface-variant">
						<li><a href="https://github.com/nicolasramos/odooclaw" class="hover:text-primary transition-colors">GitHub Repository</a></li>
						<li><a href="https://github.com/nicolasramos/odooclaw/issues" class="hover:text-primary transition-colors">Report Issue</a></li>
						<li><a href="/docs/roadmap" class="hover:text-primary transition-colors">Changelog & Roadmap</a></li>
					</ul>
				</div>
			</div>
			
			<div class="max-w-7xl mx-auto border-t border-outline-variant/10 mt-16 pt-8 flex flex-col md:flex-row justify-between items-center text-on-surface-variant text-sm gap-6">
				<p>© 2026 OdooClaw Project. Released under MIT License.</p>
				<p>Built with Astro + Starlight + Tailwind</p>
			</div>
		</footer>

		<style>
			@keyframes fade-in-up {
				from {
					opacity: 0;
					transform: translateY(20px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			
			@keyframes fade-in-left {
				from {
					opacity: 0;
					transform: translateX(40px);
				}
				to {
					opacity: 1;
					transform: translateX(0);
				}
			}
			
			.animate-fade-in-up {
				animation: fade-in-up 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
			}
			
			.animate-fade-in-left {
				animation: fade-in-left 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s forwards;
				opacity: 0;
			}
			
			.shadow-premium-lg {
				box-shadow: 0 20px 40px -8px rgba(150, 34, 170, 0.15);
			}
		</style>
	</body>
</html>
